# Catalog Lab Configuration
# Copy to .env: cp .env.example .env

# PostgreSQL (shared by OpenMetadata internal DB and e-commerce sample data)
# The OM custom PostgreSQL image creates openmetadata_db automatically.
# The init script creates a separate 'ecommerce' database for lab exercises.
POSTGRES_PASSWORD=lab_password
POSTGRES_PORT=15432

# OpenMetadata Server
# UI accessible at http://localhost:${OM_PORT}
# Default credentials: admin / admin
OM_PORT=18585

# Elasticsearch (search index for OpenMetadata catalog)
ES_PORT=19200

# Jupyter Notebooks
# Lab exercises accessible at http://localhost:${JUPYTER_PORT}
JUPYTER_PORT=18888
